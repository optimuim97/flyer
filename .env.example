# Copier en .env sur le serveur et remplir.
# docker-compose lit automatiquement le .env du même dossier.

# Email de réception des contacts/devis
SOFTARA_CONTACT_EMAIL=assidikouattara@gmail.com

# SMTP (laisser vide pour logger les messages dans la console au lieu d'envoyer)
# Exemple Gmail (avec mot de passe d'application) :
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=assidikouattara@gmail.com
#   SMTP_PASS=xxxxxxxxxxxxxxxx
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
