# Copier en .env sur le serveur et remplir.
# docker compose lit automatiquement le .env du meme dossier.

# Email de reception des contacts/devis
SOFTARA_CONTACT_EMAIL=contact@softara.tech

# =============================================================
# SMTP — choisir un des deux blocs ci-dessous
# =============================================================

# --- PRODUCTION : serveur Softara (mail.softara.tech) ----------
# Port 465 + SSL direct (SMTPS)
SMTP_HOST=mail.softara.tech
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USER=contact@softara.tech
SMTP_PASS=gW6*n3Az$vM1D6A
SMTP_FROM=contact@softara.tech
SMTP_FROM_NAME=Softara

# --- DEV / TEST : Mailtrap sandbox -----------------------------
# Decommenter et commenter le bloc PROD ci-dessus pour tester sans envoyer reellement.
# Port 2525 + STARTTLS.
# SMTP_HOST=sandbox.smtp.mailtrap.io
# SMTP_PORT=2525
# SMTP_SECURITY=starttls
# SMTP_USER=dbe3a04cb517bf
# SMTP_PASS=f21c5b1498d074
# SMTP_FROM=noreply@softara.test
# SMTP_FROM_NAME=Softara (Test)

# Laisser tous les SMTP_* vides pour logger les messages dans la console
# au lieu d'envoyer (utile en developpement local).

# =============================================================
# Administration
# =============================================================
ADMIN_USER=admin
ADMIN_PASS=changeme
# Clé secrète pour les tokens JWT — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=remplacer-par-une-vraie-cle-secrete
